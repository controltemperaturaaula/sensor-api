{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "installCommand": "composer install --ignore-platform-reqs --no-plugins --no-scripts"
  },
  "deploy": {
    "startCommand": "php artisan package:discover && php artisan serve --host=0.0.0.0 --port=$PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}