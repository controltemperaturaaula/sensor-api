{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "providers": ["php"],
    "env": {
      "NIXPACKS_PHP_VERSION": "8.3",
      "PHP_VERSION": "8.3"
    }
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}